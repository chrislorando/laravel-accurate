{
    "name": "chrislorando/laravel-accurate",
    "description": "Laravel package for Accurate Online API integration.",
    "type": "library",
    "keywords": [
        "laravel",
        "accurate",
        "accurate-online",
        "accounting"
    ],
    "homepage": "https://github.com/chrislorando/laravel-accurate",
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Manuel Lorando",
            "email": "chrismanuel.lorando@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^11.0||^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "larastan/larastan": "^3.0",
        "orchestra/testbench": "^11.0.0||^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "ChrisLorando\\LaravelAccurate\\": "src/",
            "ChrisLorando\\LaravelAccurate\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ChrisLorando\\LaravelAccurate\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ChrisLorando\\LaravelAccurate\\LaravelAccurateServiceProvider"
            ],
            "aliases": {
                "Accurate": "ChrisLorando\\LaravelAccurate\\Facades\\Accurate"
            }
        }
    },
    "support": {
        "issues": "https://github.com/chrislorando/laravel-accurate/issues",
        "source": "https://github.com/chrislorando/laravel-accurate"
    },
    "prefer-stable": true
}
